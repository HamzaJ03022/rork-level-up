{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_REVENUECAT_TEST_API_KEY": "test_EizTBuksQCAarfoBTMjPbOpDOys"
      }
    },
    "preview": {
      "distribution": "internal",
