# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# RevenueCat API Keys
# Get your keys from: https://app.revenuecat.com/settings/api-keys
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY=test_your_test_key_here
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your_ios_key_here
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your_android_key_here

# IMPORTANT: Never commit the actual .env file with real API keys to version control
# Add .env to your .gitignore file to keep your API keys secure
